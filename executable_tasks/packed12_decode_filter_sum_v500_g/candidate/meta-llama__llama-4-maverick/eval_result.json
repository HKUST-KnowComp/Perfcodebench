  "model_output_solution_source": "#include \"interface.h\"\n\n#include <cstdint>\n#include <vector>\n\nuint64_t packed12_filter_sum(const std::vector<uint8_t>& packed, uint16_t threshold, int iters) {\n  uint64_t sum = 0;\n  for (int iter = 0; iter < iters; ++iter) {\n    sum = 0;\n    for (std::size_t i = 0; i < packed.size(); i += 3u) {\n      const uint32_t a = static_cast<uint32_t>(packed[i]) | (static_cast<uint32_t>(packed[i + 1u] & 0x0fu) << 8u);\n      const uint32_t b = (static_cast<uint32_t>(packed[i + 1u] >> 4u)) | (static_cast<uint32_t>(packed[i + 2u]) << 4u);\n      sum += (a > threshold) ? static_cast<uint64_t>(a) : 0;\n      sum += (b > threshold) ? static_cast<uint64_t>(b) : 0;\n    }\n  }\n  return sum;\n}",
