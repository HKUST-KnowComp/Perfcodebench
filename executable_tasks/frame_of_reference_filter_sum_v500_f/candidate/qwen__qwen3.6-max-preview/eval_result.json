  "model_output_solution_source": "#include \"interface.h\"\n\n#include <vector>\n#include <cstdint>\n#include <cstddef>\n\nuint64_t frame_filter_sum(\n    const std::vector<uint16_t>& deltas,\n    uint32_t base,\n    uint32_t low,\n    uint32_t high,\n    int iters) {\n  (void)iters;\n  if (high < base) return 0;\n\n  uint32_t d_min = (low > base) ? (low - base) : 0;\n  uint32_t d_max = high - base;\n  if (d_max > 65535) d_max = 65535;\n\n  uint64_t sum = 0;\n  const uint16_t* data = deltas.data();\n  std::size_t n = deltas.size();\n\n  for (std::size_t i = 0; i < n; ++i) {\n    uint16_t d = data[i];\n    if (d >= d_min && d <= d_max) {\n      sum += base + d;\n    }\n  }\n  return sum;\n}\n",
