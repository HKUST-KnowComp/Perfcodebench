  "model_output_solution_source": "#include \"interface.h\"\n\nuint64_t varint_sum(const std::vector<uint8_t>& encoded, int iters) {\n  if (iters <= 0) {\n    return 0;\n  }\n  const uint8_t* p = encoded.data();\n  const uint8_t* end = p + encoded.size();\n  uint64_t sum = 0;\n  while (p < end) {\n    uint64_t value = 0;\n    uint32_t shift = 0;\n    for (;;) {\n      uint8_t byte = *p++;\n      value |= static_cast<uint64_t>(byte & 0x7Fu) << shift;\n      if ((byte & 0x80u) == 0u) {\n        break;\n      }\n      shift += 7u;\n    }\n    sum += value;\n  }\n  return sum;\n}\n",
