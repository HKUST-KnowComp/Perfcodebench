  "model_output_solution_source": "#include \"interface.h\"\n\n#include <vector>\n#include <cstdint>\n\nuint64_t range_bucket_sum(\n    const std::vector<uint32_t>& boundaries,\n    const std::vector<uint32_t>& probes,\n    int iters) {\n  uint64_t total_sum = 0;\n  const size_t n_boundaries = boundaries.size();\n  \n  for (int iter = 0; iter < iters; ++iter) {\n    uint64_t current_iter_sum = 0;\n    size_t b_idx = 0;\n    \n    for (uint32_t probe : probes) {\n      // Advance b_idx while the current boundary is less than or equal to the probe\n      while (b_idx < n_boundaries && boundaries[b_idx] <= probe) {\n        b_idx++;\n      }\n      current_iter_sum += b_idx;\n    }\n    total_sum = current_iter_sum;\n  }\n  return total_sum;\n}",
