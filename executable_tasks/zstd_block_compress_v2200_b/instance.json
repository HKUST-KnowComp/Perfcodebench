{
  "task_id": "zstd_block_compress_v2200_b",
  "title": "Optimize Zstandard block compression throughput [medium block mixed]",
  "goal": "Compress a large buffer with Zstandard and return the compressed size while preserving lossless roundtrip correctness.",
  "metric": "median elapsed_ns over repeated runs; lower is better",
  "correctness_rule": "Decompressed output must exactly match the original input bytes.",
  "allowed_external_includes": [
    "zstd.h"
  ],
  "build": {
    "compiler": "g++",
    "cxxflags": [
      "-O3",
      "-std=c++17",
      "-DZSTD_DISABLE_ASM=1",
      "-I{task_dir}/harness",
      "-I{root}/external/zstd/lib"
    ],
    "sources": [
