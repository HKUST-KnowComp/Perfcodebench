  "model_output_solution_source": "#include \"interface.h\"\n#include \"xxhash.h\"\n#include <string>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1 << 10;\n}\n\nuint64_t chunked_hash(const std::string& input) {\n  uint64_t acc = 0;\n  const char* data = input.data();\n  std::size_t size = input.size();\n  std::size_t offset = 0;\n\n  for (; offset + kChunkSize <= size; offset += kChunkSize) {\n    acc ^= static_cast<uint64_t>(XXH3_64bits(data + offset, kChunkSize));\n    acc = (acc << 1) | (acc >> 63);\n  }\n\n  if (offset < size) {\n    acc ^= static_cast<uint64_t>(XXH3_64bits(data + offset, size - offset));\n    acc = (acc << 1) | (acc >> 63);\n  }\n\n  return acc;\n}\n",
