  "model_output_solution_source": "#include \"interface.h\"\n\n#include <roaring.h>\n\nuint64_t many_union_cardinality(\n    const std::vector<uint32_t>& offsets,\n    const std::vector<uint32_t>& values) {\n  roaring_bitmap_t *r = roaring_bitmap_create();\n  \n  const size_t num_shards = offsets.size() > 0 ? offsets.size() - 1 : 0;\n  \n  for (size_t shard = 0; shard < num_shards; ++shard) {\n    const uint32_t begin = offsets[shard];\n    const uint32_t end = offsets[shard + 1];\n    if (end > begin) {\n      roaring_bitmap_add_many(r, end - begin, values.data() + begin);\n    }\n  }\n  \n  uint64_t cardinality = roaring_bitmap_get_cardinality(r);\n  roaring_bitmap_free(r);\n  \n  return cardinality;\n}",
