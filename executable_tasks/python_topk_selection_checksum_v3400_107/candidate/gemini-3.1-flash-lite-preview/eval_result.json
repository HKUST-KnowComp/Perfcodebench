  "model_output_solution_source": "import heapq\n\ndef run(scores: list[int], k: int, iters: int) -> int:\n    # Pre-calculate the items as (-score, index) to use min-heap for top-k\n    # This allows us to use heapq.nsmallest which is O(N log K)\n    indexed_scores = [(-s, i) for i, s in enumerate(scores)]\n    \n    h = 0\n    for _ in range(iters):\n        # nsmallest is highly optimized in CPython\n        top_k = heapq.nsmallest(k, indexed_scores)\n        \n        h = 1469598103934665603\n        for neg_score, index in top_k:\n            score = -neg_score\n            h ^= ((score << 32) ^ index)\n            h = (h * 1099511628211) & 0xFFFFFFFFFFFFFFFF\n    return h",
