  "model_output_solution_source": "#include \"interface.h\"\n\n#include <algorithm>\n#include <cstdint>\n#include <cstdlib>\n#include <vector>\n\nint64_t allpairs_l1_sum(const std::vector<int32_t>& xs, const std::vector<int32_t>& ys, int iters) {\n    if (iters == 0) return 0;\n    int64_t n = static_cast<int64_t>(xs.size());\n    if (n < 2) return 0;\n    std::vector<int32_t> sx = xs;\n    std::vector<int32_t> sy = ys;\n    std::sort(sx.begin(), sx.end());\n    std::sort(sy.begin(), sy.end());\n    int64_t total = 0;\n    for (int64_t i = 0; i < n; ++i) {\n        total += static_cast<int64_t>(sx[i]) * (2 * i - n + 1);\n        total += static_cast<int64_t>(sy[i]) * (2 * i - n + 1);\n    }\n    return total;\n}",
