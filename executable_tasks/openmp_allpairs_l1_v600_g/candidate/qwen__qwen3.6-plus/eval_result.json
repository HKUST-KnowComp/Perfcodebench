  "model_output_solution_source": "#include \"interface.h\"\n#include <algorithm>\n#include <cstdint>\n#include <vector>\n\nint64_t allpairs_l1_sum(const std::vector<int32_t>& xs, const std::vector<int32_t>& ys, int iters) {\n    (void)iters;\n    std::size_t n = xs.size();\n    if (n <= 1) return 0;\n\n    std::vector<int32_t> sx = xs;\n    std::vector<int32_t> sy = ys;\n    std::sort(sx.begin(), sx.end());\n    std::sort(sy.begin(), sy.end());\n\n    int64_t total = 0;\n    int64_t n64 = static_cast<int64_t>(n);\n    for (std::size_t k = 0; k < n; ++k) {\n        int64_t coeff = static_cast<int64_t>(2 * k) - n64 + 1;\n        total += coeff * (static_cast<int64_t>(sx[k]) + static_cast<int64_t>(sy[k]));\n    }\n\n    return total;\n}",
