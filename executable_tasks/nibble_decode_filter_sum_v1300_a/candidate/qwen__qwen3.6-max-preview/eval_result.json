  "model_output_solution_source": "#include \"interface.h\"\n#include <vector>\n\nuint64_t nibble_filter_sum(const std::vector<uint8_t>& packed, uint8_t threshold, int iters) {\n    if (iters <= 0) return 0;\n    uint64_t sum = 0;\n    for (uint8_t b : packed) {\n        uint8_t lo = b & 0x0F;\n        uint8_t hi = b >> 4;\n        if (lo > threshold) sum += lo;\n        if (hi > threshold) sum += hi;\n    }\n    return sum;\n}",
