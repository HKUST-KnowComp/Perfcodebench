  "model_output_solution_source": "#include \"interface.h\"\n\n#include <fast_float/fast_float.h>\n\ndouble parse_sum(const std::string& input) {\n  const char* p = input.data();\n  const char* end = p + input.size();\n  double sum = 0.0;\n  \n  while (p < end) {\n    // Skip whitespace manually (fast_float doesn't handle leading whitespace)\n    while (p < end && (*p == ' ' || *p == '\\t' || *p == '\\n' || *p == '\\r' || *p == '\\v' || *p == '\\f')) {\n      ++p;\n    }\n    if (p >= end) break;\n    \n    double value;\n    auto result = fast_float::from_chars(p, end, value);\n    if (result.ec == std::errc{}) {\n      sum += value;\n      p = result.ptr;\n    } else {\n      // Skip non-parseable character\n      ++p;\n    }\n  }\n  return sum;\n}\n",
