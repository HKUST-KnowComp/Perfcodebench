  "model_output_solution_source": "#include \"interface.h\"\n#include <cstdint>\n#include <vector>\n\nuint64_t packed12_filter_sum(const std::vector<uint8_t>& packed, uint16_t threshold, int iters) {\n    const uint32_t thr = threshold;\n    const uint8_t* data = packed.data();\n    const size_t n = packed.size();\n    uint64_t sum = 0;\n    for (int iter = 0; iter < iters; ++iter) {\n        uint64_t local_sum = 0;\n        for (size_t i = 0; i < n; i += 3) {\n            uint32_t a = data[i];\n            uint32_t b = data[i + 1];\n            uint32_t c = data[i + 2];\n            uint32_t v0 = a | ((b & 0x0F) << 8);\n            uint32_t v1 = (b >> 4) | (c << 4);\n            if (v0 > thr) local_sum += v0;\n            if (v1 > thr) local_sum += v1;\n        }\n        sum = local_sum;\n    }\n    return sum;\n}\n",
