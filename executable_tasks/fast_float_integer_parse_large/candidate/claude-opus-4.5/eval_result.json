  "model_output_solution_source": "#include \"interface.h\"\n\ndouble parse_sum(const std::string& input) {\n  const char* p = input.data();\n  const char* end = p + input.size();\n  long long sum = 0;\n  while (p < end) {\n    // Skip whitespace/newlines\n    while (p < end && (*p == '\\n' || *p == ' ' || *p == '\\t' || *p == '\\r')) {\n      ++p;\n    }\n    if (p >= end) break;\n    \n    // Parse sign\n    bool neg = false;\n    if (*p == '-') {\n      neg = true;\n      ++p;\n    } else if (*p == '+') {\n      ++p;\n    }\n    \n    // Parse digits\n    long long val = 0;\n    while (p < end && *p >= '0' && *p <= '9') {\n      val = val * 10 + (*p - '0');\n      ++p;\n    }\n    \n    sum += neg ? -val : val;\n  }\n  return static_cast<double>(sum);\n}",
