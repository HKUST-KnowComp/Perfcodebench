  "model_output_solution_source": "#include \"interface.h\"\n\n#include <cstdint>\n#include <cstring>\n#include <vector>\n\nuint64_t distinct_count(const std::vector<uint32_t>& keys, uint32_t key_space, int iters) {\n  // Bitmap: 1 bit per possible key value\n  const size_t num_words = (static_cast<size_t>(key_space) + 63) / 64;\n  std::vector<uint64_t> bitmap(num_words);\n\n  uint64_t count = 0;\n  for (int iter = 0; iter < iters; ++iter) {\n    std::memset(bitmap.data(), 0, num_words * sizeof(uint64_t));\n\n    for (uint32_t key : keys) {\n      bitmap[key >> 6] |= (1ULL << (key & 63));\n    }\n\n    count = 0;\n    for (size_t i = 0; i < num_words; ++i) {\n      count += static_cast<uint64_t>(__builtin_popcountll(bitmap[i]));\n    }\n  }\n  return count;\n}\n",
