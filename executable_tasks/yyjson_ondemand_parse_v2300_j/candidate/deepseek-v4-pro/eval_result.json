  "model_output_solution_source": "#include \"interface.h\"\n#include <yyjson.h>\n\nuint64_t compute_checksum(const std::string& json_input) {\n    yyjson_doc *doc = yyjson_read(json_input.c_str(), json_input.size(), 0);\n    yyjson_val *root = yyjson_doc_get_root(doc);\n    uint64_t sum = 0;\n    yyjson_arr_iter iter;\n    yyjson_arr_iter_init(root, &iter);\n    yyjson_val *item;\n    while ((item = yyjson_arr_iter_next(&iter))) {\n        sum += yyjson_get_uint(yyjson_obj_get(item, \"id\"));\n        yyjson_val *nested = yyjson_obj_get(item, \"nested\");\n        sum += yyjson_get_uint(yyjson_obj_get(nested, \"a\"));\n        sum += yyjson_get_uint(yyjson_obj_get(nested, \"b\"));\n    }\n    yyjson_doc_free(doc);\n    return sum;\n}",
