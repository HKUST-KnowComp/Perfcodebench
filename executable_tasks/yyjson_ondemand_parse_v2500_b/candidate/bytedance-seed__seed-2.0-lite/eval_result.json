  "model_output_solution_source": "#include \"interface.h\"\n#include <yyjson.h>\n\nuint64_t compute_checksum(const std::string& json_input) {\n    yyjson_doc* doc = yyjson_read(json_input.data(), json_input.size(), YYJSON_READ_FAST);\n    uint64_t sum = 0;\n    if (!doc) return sum;\n    \n    yyjson_val* root = yyjson_doc_get_root(doc);\n    const size_t arr_len = yyjson_arr_size(root);\n    \n    for (size_t i = 0; i < arr_len; ++i) {\n        yyjson_val* item = yyjson_arr_get(root, i);\n        sum += yyjson_get_uint(yyjson_obj_get(item, \"id\"));\n        \n        yyjson_val* nested = yyjson_obj_get(item, \"nested\");\n        sum += yyjson_get_uint(yyjson_obj_get(nested, \"a\"));\n        sum += yyjson_get_uint(yyjson_obj_get(nested, \"b\"));\n    }\n    \n    yyjson_doc_free(doc);\n    return sum;\n}",
