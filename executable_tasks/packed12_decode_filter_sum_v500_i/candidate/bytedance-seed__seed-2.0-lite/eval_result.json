  "model_output_solution_source": "#include \"interface.h\"\n\nuint64_t packed12_filter_sum(const std::vector<uint8_t>& packed, uint16_t threshold, int iters) {\n  uint64_t sum = 0;\n  const uint32_t thresh = static_cast<uint32_t>(threshold);\n  const std::size_t n_bytes = packed.size();\n  \n  for (int iter = 0; iter < iters; ++iter) {\n    sum = 0;\n    for (std::size_t i = 0; i < n_bytes; i += 3) {\n      const uint32_t a = static_cast<uint32_t>(packed[i]) | \n                          (static_cast<uint32_t>(packed[i+1] & 0x0FU) << 8);\n      const uint32_t b = (static_cast<uint32_t>(packed[i+1] >> 4)) | \n                          (static_cast<uint32_t>(packed[i+2]) << 4);\n      \n      if (a > thresh) sum += a;\n      if (b > thresh) sum += b;\n    }\n  }\n  return sum;\n}",
