  "model_output_solution_source": "#include \"interface.h\"\n\n#include <cstdint>\n#include <vector>\n\nuint64_t run_end_sum(\n    const std::vector<uint32_t>& run_ends,\n    const std::vector<uint32_t>& values,\n    int iters) {\n  const std::size_t n = values.size();\n  if (iters <= 0 || n == 0) return 0;\n\n  uint64_t sum = 0;\n  for (int iter = 0; iter < iters; ++iter) {\n    uint64_t iter_sum = 0;\n    uint32_t prev = 0;\n\n    const uint32_t* re = run_ends.data();\n    const uint32_t* val = values.data();\n\n    for (std::size_t i = 0; i < n; ++i) {\n      const uint32_t end = re[i];\n      iter_sum += static_cast<uint64_t>(end - prev) * static_cast<uint64_t>(val[i]);\n      prev = end;\n    }\n\n    sum = iter_sum;\n  }\n  return sum;\n}\n",
