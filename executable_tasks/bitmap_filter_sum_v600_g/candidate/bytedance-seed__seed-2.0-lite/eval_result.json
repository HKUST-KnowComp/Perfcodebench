  "model_output_solution_source": "#include \"interface.h\"\n#include <vector>\n#include <cstdint>\n\nuint64_t bitmap_filter_sum(\n    const std::vector<uint32_t>& enabled_keys,\n    const std::vector<uint32_t>& probe_keys,\n    const std::vector<uint32_t>& values,\n    uint32_t key_space,\n    int iters) {\n    // Pre-enable keys once in a contiguous bitmap, outside iteration loop\n    std::vector<uint8_t> enabled(key_space, 0);\n    for (uint32_t key : enabled_keys) {\n        enabled[key] = 1;\n    }\n\n    uint64_t sum = 0;\n    for (int iter = 0; iter < iters; ++iter) {\n        sum = 0;\n        for (size_t i = 0; i < probe_keys.size(); ++i) {\n            if (enabled[probe_keys[i]]) {\n                sum += static_cast<uint64_t>(values[i]);\n            }\n        }\n    }\n    return sum;\n}",
