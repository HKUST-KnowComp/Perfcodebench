  "model_output_solution_source": "#include \"interface.h\"\n#include <algorithm>\n#include <vector>\n#include <cstdint>\n\nint64_t allpairs_l1_sum(const std::vector<int32_t>& xs, const std::vector<int32_t>& ys, int iters) {\n    std::size_t n = xs.size();\n    if (n <= 1) return 0;\n\n    std::vector<int32_t> sx(xs);\n    std::vector<int32_t> sy(ys);\n\n    std::sort(sx.begin(), sx.end());\n    std::sort(sy.begin(), sy.end());\n\n    int64_t sum_x = 0;\n    int64_t sum_y = 0;\n\n    for (std::size_t k = 0; k < n; ++k) {\n        int64_t coeff = (int64_t)k * 2 - (int64_t)n + 1;\n        sum_x += (int64_t)sx[k] * coeff;\n        sum_y += (int64_t)sy[k] * coeff;\n    }\n\n    return sum_x + sum_y;\n}",
