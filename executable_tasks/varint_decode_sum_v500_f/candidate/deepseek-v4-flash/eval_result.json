  "model_output_solution_source": "#include \"interface.h\"\n#include <cstddef>\n\nuint64_t varint_sum(const std::vector<uint8_t>& encoded, int iters) {\n    if (iters <= 0) return 0;\n    uint64_t sum = 0;\n    const uint8_t* ptr = encoded.data();\n    const uint8_t* end = ptr + encoded.size();\n    while (ptr < end) {\n        uint64_t value = 0;\n        uint64_t shift = 0;\n        while (true) {\n            uint8_t byte = *ptr++;\n            value |= static_cast<uint64_t>(byte & 0x7F) << shift;\n            if ((byte & 0x80) == 0) break;\n            shift += 7;\n        }\n        sum += value;\n    }\n    return sum;\n}",
