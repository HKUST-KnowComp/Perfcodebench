  "model_output_solution_source": "#include \"interface.h\"\n#include <roaring.h>\n\nuint64_t many_union_cardinality(\n    const std::vector<uint32_t>& offsets,\n    const std::vector<uint32_t>& values) {\n  roaring_bitmap_t* union_bitmap = roaring_bitmap_create();\n  if (!union_bitmap) return 0;\n\n  for (std::size_t shard = 0; shard + 1 < offsets.size(); ++shard) {\n    const uint32_t begin = offsets[shard];\n    const uint32_t end = offsets[shard + 1];\n    const size_t count = end - begin;\n    if (count == 0) continue;\n    roaring_bitmap_add_many(union_bitmap, count, &values[begin]);\n  }\n\n  const uint64_t result = static_cast<uint64_t>(roaring_bitmap_get_cardinality(union_bitmap));\n  roaring_bitmap_free(union_bitmap);\n  return result;\n}",
