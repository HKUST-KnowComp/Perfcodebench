  "model_output_solution_source": "#include \"interface.h\"\n#include \"xxhash.h\"\n#include <string>\n\nuint64_t hash_lines(const std::string& input) {\n  uint64_t acc = 1469598103934665603ULL;\n  const char* data = input.data();\n  const size_t size = input.size();\n  size_t start = 0;\n\n  while (start < size) {\n    size_t end = start;\n    while (end < size && data[end] != '\\n') {\n      ++end;\n    }\n    \n    // Hash the line segment directly from the input buffer without allocation\n    uint64_t line_hash = XXH64(data + start, end - start, 0);\n    \n    acc ^= line_hash;\n    acc *= 1099511628211ULL;\n    \n    start = end + 1;\n  }\n  \n  return acc;\n}",
