  "model_output_solution_source": "def run(deltas: list[int], iters: int) -> int:\n    n = len(deltas)\n    if n == 0:\n        return 0\n    \n    # The sum of prefix sums is: \n    # S = d0 + (d0 + d1) + (d0 + d1 + d2) ...\n    # S = n*d0 + (n-1)*d1 + (n-2)*d2 + ... + 1*dn-1\n    # This can be computed in O(N) instead of O(iters * N).\n    \n    weighted_sum = 0\n    for i, d in enumerate(deltas):\n        weighted_sum += (n - i) * d\n    \n    # Each iteration adds the weighted_sum and the constant offset for each element\n    # Total = iters * (weighted_sum + n * 0x9E3779B1)\n    constant_offset = 0x9E3779B1\n    total_per_iter = weighted_sum + n * constant_offset\n    \n    return iters * total_per_iter",
