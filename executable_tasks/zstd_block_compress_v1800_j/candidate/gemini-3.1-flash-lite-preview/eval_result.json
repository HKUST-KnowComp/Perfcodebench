  "model_output_solution_source": "#include \"interface.h\"\n#include \"zstd.h\"\n#include <string>\n\nint compress_payload(const std::string& input, std::string& compressed) {\n  if (input.empty()) {\n    compressed.clear();\n    return 0;\n  }\n\n  size_t bound = ZSTD_compressBound(input.size());\n  compressed.resize(bound);\n\n  // Using compression level 3 (default) provides a much better balance of \n  // throughput vs ratio compared to level 19, which is extremely slow.\n  size_t n = ZSTD_compress(\n      compressed.data(), \n      compressed.size(), \n      input.data(), \n      input.size(), \n      3);\n\n  if (ZSTD_isError(n)) {\n    return -1;\n  }\n\n  compressed.resize(n);\n  return static_cast<int>(n);\n}",
