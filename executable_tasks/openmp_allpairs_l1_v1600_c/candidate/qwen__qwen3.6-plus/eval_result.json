  "model_output_solution_source": "#include \"interface.h\"\n#include <algorithm>\n#include <vector>\n\nint64_t allpairs_l1_sum(const std::vector<int32_t>& xs, const std::vector<int32_t>& ys, int iters) {\n    size_t n = xs.size();\n    if (n <= 1) return 0;\n    \n    std::vector<int32_t> sx(xs);\n    std::vector<int32_t> sy(ys);\n    std::sort(sx.begin(), sx.end());\n    std::sort(sy.begin(), sy.end());\n    \n    int64_t sum_x = 0;\n    int64_t sum_y = 0;\n    int64_t prefix_x = 0;\n    int64_t prefix_y = 0;\n    \n    for (size_t k = 0; k < n; ++k) {\n        sum_x += static_cast<int64_t>(sx[k]) * k - prefix_x;\n        prefix_x += sx[k];\n        \n        sum_y += static_cast<int64_t>(sy[k]) * k - prefix_y;\n        prefix_y += sy[k];\n    }\n    \n    return (sum_x + sum_y) * iters;\n}\n",
