  "model_output_solution_source": "#include \"interface.h\"\n#include <vector>\n\nuint64_t bitmap_filter_sum(\n    const std::vector<uint32_t>& enabled_keys,\n    const std::vector<uint32_t>& probe_keys,\n    const std::vector<uint32_t>& values,\n    uint32_t key_space,\n    int iters) {\n    std::vector<uint8_t> bitmap(key_space, 0);\n    for (uint32_t k : enabled_keys) {\n        bitmap[k] = 1;\n    }\n\n    const uint32_t* pk = probe_keys.data();\n    const uint32_t* vals = values.data();\n    size_t n = probe_keys.size();\n    \n    uint64_t result = 0;\n    for (int iter = 0; iter < iters; ++iter) {\n        uint64_t sum = 0;\n        for (size_t i = 0; i < n; ++i) {\n            sum += static_cast<uint64_t>(vals[i]) * bitmap[pk[i]];\n        }\n        result = sum;\n    }\n    return result;\n}",
