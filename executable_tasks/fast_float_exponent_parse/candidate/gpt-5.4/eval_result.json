  "model_output_solution_source": "#include \"interface.h\"\n\n#include \"fast_float/fast_float.h\"\n\n#include <string>\n\n// Parse newline-delimited scientific-notation doubles and return their sum.\n// Optimized for throughput by using fast_float directly on the input buffer,\n// avoiding locale-dependent strtod and any temporary allocations.\ndouble parse_sum(const std::string& input) {\n  const char* p = input.data();\n  const char* const end = p + input.size();\n  double sum = 0.0;\n\n  while (p < end) {\n    double value;\n    auto result = fast_float::from_chars(p, end, value);\n    if (result.ec != std::errc()) {\n      break;\n    }\n\n    sum += value;\n    p = result.ptr;\n\n    if (p < end && *p == '\\n') {\n      ++p;\n    }\n  }\n\n  return sum;\n}\n",
