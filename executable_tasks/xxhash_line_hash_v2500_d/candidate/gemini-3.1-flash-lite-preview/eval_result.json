  "model_output_solution_source": "#include \"interface.h\"\n#include \"xxhash.h\"\n#include <string>\n#include <cstdint>\n\nuint64_t hash_lines(const std::string& input) {\n  uint64_t acc = 1469598103934665603ULL;\n  const char* data = input.data();\n  const char* end_ptr = data + input.size();\n  const char* start = data;\n\n  while (start < end_ptr) {\n    const char* current = start;\n    while (current < end_ptr && *current != '\\n') {\n      ++current;\n    }\n    \n    // Hash the segment directly from the input buffer without allocation\n    acc ^= static_cast<uint64_t>(XXH64(start, static_cast<size_t>(current - start), 0));\n    acc *= 1099511628211ULL;\n    \n    start = current + 1;\n  }\n  \n  return acc;\n}",
