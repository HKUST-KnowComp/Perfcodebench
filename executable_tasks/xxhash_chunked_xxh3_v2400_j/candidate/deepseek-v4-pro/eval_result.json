  "model_output_solution_source": "#include \"interface.h\"\n\n#include \"xxhash.h\"\n\n#include <cstdint>\n#include <string>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1 << 10; // 1024\n}\n\nuint64_t chunked_hash(const std::string& input) {\n    const char* data = input.data();\n    std::size_t size = input.size();\n    uint64_t acc = 0;\n    std::size_t offset = 0;\n\n    // Process full chunks\n    for (; offset + kChunkSize <= size; offset += kChunkSize) {\n        acc ^= XXH3_64bits(data + offset, kChunkSize);\n        acc = (acc << 1) | (acc >> 63);\n    }\n\n    // Process final partial chunk\n    if (offset < size) {\n        acc ^= XXH3_64bits(data + offset, size - offset);\n        acc = (acc << 1) | (acc >> 63);\n    }\n\n    return acc;\n}\n",
