  "model_output_solution_source": "#include \"interface.h\"\n\n#include <algorithm>\n\nuint64_t topk_sum(const std::vector<uint32_t>& scores, int k, int iters) {\n  std::vector<uint32_t> tmp;\n  uint64_t sum = 0;\n  for (int iter = 0; iter < iters; ++iter) {\n    tmp = scores;\n    // Use nth_element to partition: elements >= k-th largest come first\n    std::nth_element(tmp.begin(), tmp.begin() + k, tmp.end(), std::greater<uint32_t>());\n    sum = 0;\n    for (int i = 0; i < k; ++i) {\n      sum += static_cast<uint64_t>(tmp[static_cast<std::size_t>(i)]);\n    }\n  }\n  return sum;\n}\n",
