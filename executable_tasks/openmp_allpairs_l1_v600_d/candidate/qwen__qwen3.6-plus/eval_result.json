  "model_output_solution_source": "#include \"interface.h\"\n#include <algorithm>\n#include <vector>\n#include <cstdint>\n\nint64_t allpairs_l1_sum(const std::vector<int32_t>& xs, const std::vector<int32_t>& ys, int iters) {\n    std::size_t n = xs.size();\n    if (n < 2) return 0;\n    \n    std::vector<int32_t> sx(xs);\n    std::vector<int32_t> sy(ys);\n    \n    std::sort(sx.begin(), sx.end());\n    std::sort(sy.begin(), sy.end());\n    \n    int64_t sum_x = 0;\n    int64_t sum_y = 0;\n    int64_t coeff = 1 - static_cast<int64_t>(n);\n    \n    for (std::size_t i = 0; i < n; ++i) {\n        sum_x += static_cast<int64_t>(sx[i]) * coeff;\n        sum_y += static_cast<int64_t>(sy[i]) * coeff;\n        coeff += 2;\n    }\n    \n    return sum_x + sum_y;\n}",
