  "model_output_solution_source": "#include \"interface.h\"\n#include <vector>\n#include <algorithm>\n\nuint64_t remap_checksum(\n    const std::vector<uint32_t>& keys,\n    const std::vector<uint32_t>& values,\n    const std::vector<uint32_t>& probes,\n    int iters) {\n  if (keys.empty()) return 0;\n\n  uint32_t max_key = 0;\n  for (uint32_t k : keys) {\n    if (k > max_key) max_key = k;\n  }\n\n  std::vector<uint32_t> lookup(max_key + 1, 0);\n  for (size_t i = 0; i < keys.size(); ++i) {\n    lookup[keys[i]] = values[i];\n  }\n\n  uint64_t hash = 0;\n  for (int iter = 0; iter < iters; ++iter) {\n    uint64_t current_hash = 1469598103934665603ULL;\n    for (uint32_t probe : probes) {\n      uint32_t val = lookup[probe];\n      current_hash ^= val;\n      current_hash *= 1099511628211ULL;\n    }\n    hash = current_hash;\n  }\n  return hash;\n}",
