  "model_output_solution_source": "#include \"interface.h\"\n#include \"roaring.h\"\n\nuint64_t many_union_cardinality(\n    const std::vector<uint32_t>& offsets,\n    const std::vector<uint32_t>& values) {\n  if (offsets.empty()) return 0;\n\n  roaring_bitmap_t* bitmap = roaring_bitmap_create();\n  if (!bitmap) return 0;\n\n  for (std::size_t shard = 0; shard + 1 < offsets.size(); ++shard) {\n    const uint32_t begin = offsets[shard];\n    const uint32_t end = offsets[shard + 1];\n    \n    // Use roaring_bitmap_add_array for bulk insertion of sorted/unsorted data\n    // Since the input shards are sorted, this is very efficient.\n    roaring_bitmap_add_array(bitmap, values.data() + begin, end - begin);\n  }\n\n  uint64_t cardinality = roaring_bitmap_get_cardinality(bitmap);\n  roaring_bitmap_destroy(bitmap);\n  return cardinality;\n}",
