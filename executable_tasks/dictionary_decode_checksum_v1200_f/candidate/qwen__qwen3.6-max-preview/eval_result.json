  "model_output_solution_source": "#include \"interface.h\"\n#include <cstdint>\n#include <string>\n#include <vector>\n\nuint64_t dictionary_decode_checksum(\n    const std::vector<std::string>& dict,\n    const std::vector<uint32_t>& codes,\n    int iters) {\n  uint64_t hash = 0;\n  constexpr uint64_t fnv_prime = 1099511628211ULL;\n  constexpr uint64_t fnv_offset = 1469598103934665603ULL;\n\n  for (int iter = 0; iter < iters; ++iter) {\n    hash = fnv_offset;\n    for (uint32_t code : codes) {\n      const std::string& token = dict[static_cast<std::size_t>(code)];\n      hash ^= static_cast<uint64_t>(token.size());\n      hash *= fnv_prime;\n      hash ^= static_cast<uint64_t>(token.empty() ? 0u : static_cast<unsigned char>(token[0]));\n      hash *= fnv_prime;\n    }\n  }\n  return hash;\n}\n",
