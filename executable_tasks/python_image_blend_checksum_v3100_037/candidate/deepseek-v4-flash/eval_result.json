  "model_output_solution_source": "def run(src: bytearray, dst: bytearray, width: int, height: int, iters: int) -> int:\n    if iters == 0:\n        return 0\n    pixels = width * height\n    h = 1469598103934665603\n    for i in range(pixels):\n        base = i * 4\n        a = src[base + 3]\n        na = 255 - a\n        # blend each channel\n        r = (src[base] * a + dst[base] * na + 127) // 255\n        g = (src[base + 1] * a + dst[base + 1] * na + 127) // 255\n        b = (src[base + 2] * a + dst[base + 2] * na + 127) // 255\n        # update hash with the four output bytes\n        for byte in (r, g, b, 255):\n            h ^= byte\n            h = (h * 1099511628211) & 0xFFFFFFFFFFFFFFFF\n    return h\n",
