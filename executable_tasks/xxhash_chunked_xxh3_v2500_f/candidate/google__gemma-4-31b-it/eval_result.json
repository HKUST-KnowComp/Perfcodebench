  "model_output_solution_source": "#include \"interface.h\"\n#include \"xxhash.h\"\n#include <algorithm>\n#include <string>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1 << 10;\n}\n\nuint64_t chunked_hash(const std::string& input) {\n  uint64_t acc = 0;\n  const std::size_t size = input.size();\n  const char* data = input.data();\n\n  for (std::size_t offset = 0; offset < size; offset += kChunkSize) {\n    const std::size_t take = std::min(kChunkSize, size - offset);\n    // Use the pointer directly to avoid std::string allocations from substr()\n    acc ^= static_cast<uint64_t>(XXH3_64bits(data + offset, take));\n    acc = (acc << 1) | (acc >> 63);\n  }\n  return acc;\n}",
