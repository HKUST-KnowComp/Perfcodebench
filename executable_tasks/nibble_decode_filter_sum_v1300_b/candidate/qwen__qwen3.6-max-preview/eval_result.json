  "model_output_solution_source": "#include \"interface.h\"\n\n#include <vector>\n#include <cstdint>\n\nuint64_t nibble_filter_sum(const std::vector<uint8_t>& packed, uint8_t threshold, int iters) {\n    uint64_t sum = 0;\n    const uint8_t* data = packed.data();\n    std::size_t n = packed.size();\n    \n    for (int iter = 0; iter < iters; ++iter) {\n        uint64_t s = 0;\n        for (std::size_t i = 0; i < n; ++i) {\n            uint32_t b = data[i];\n            uint32_t lo = b & 15u;\n            uint32_t hi = b >> 4u;\n            s += (lo > threshold) ? lo : 0;\n            s += (hi > threshold) ? hi : 0;\n        }\n        sum = s;\n    }\n    return sum;\n}",
