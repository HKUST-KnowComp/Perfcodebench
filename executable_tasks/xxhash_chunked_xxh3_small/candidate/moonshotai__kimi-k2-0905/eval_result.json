  "model_output_solution_source": "#include \"interface.h\"\n#include \"xxhash.h\"\n#include <algorithm>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1 << 10;\n}\n\nuint64_t chunked_hash(const std::string& input) {\n    uint64_t acc = 0;\n    const char* data = input.data();\n    const std::size_t len = input.size();\n    std::size_t offset = 0;\n\n    for (; offset + kChunkSize <= len; offset += kChunkSize) {\n        uint64_t h = XXH3_64bits(data + offset, kChunkSize);\n        acc ^= h;\n        acc = (acc << 1) | (acc >> 63);\n    }\n    if (std::size_t rem = len - offset) {\n        uint64_t h = XXH3_64bits(data + offset, rem);\n        acc ^= h;\n        acc = (acc << 1) | (acc >> 63);\n    }\n    return acc;\n}",
