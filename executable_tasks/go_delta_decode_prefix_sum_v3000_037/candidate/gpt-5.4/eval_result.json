  "model_output_solution_source": "package main\n\nfunc run(deltas []int32, iters int) uint64 {\n\t// Fuse delta decoding and aggregation to avoid the intermediate values slice\n\t// and the second pass over decoded values.\n\tconst bias = uint64(0x9E3779B1)\n\tn := uint64(len(deltas))\n\tvar total uint64\n\n\tfor iter := 0; iter < iters; iter++ {\n\t\tvar current int64\n\t\tvar sum uint64\n\t\tfor _, d := range deltas {\n\t\t\tcurrent += int64(d)\n\t\t\tsum += uint64(current) + bias\n\t\t}\n\t\t// Equivalent to adding bias per element during the loop.\n\t\t// Kept as direct fused accumulation for minimal work.\n\t\ttotal = sum\n\t\t_ = n\n\t}\n\treturn total\n}\n",
