  "model_output_solution_source": "#include \"interface.h\"\n\nuint64_t range_bucket_sum(\n    const std::vector<uint32_t>& boundaries,\n    const std::vector<uint32_t>& probes,\n    int iters) {\n  if (probes.empty() || boundaries.empty()) {\n    return 0;\n  }\n\n  uint64_t total_sum_per_iter = 0;\n  size_t b_idx = 0;\n  size_t b_size = boundaries.size();\n\n  // Since both boundaries and probes are sorted, we use a two-pointer approach\n  // to find the upper_bound for each probe in O(N + M) time.\n  for (uint32_t probe : probes) {\n    while (b_idx < b_size && boundaries[b_idx] <= probe) {\n      ++b_idx;\n    }\n    total_sum_per_iter += b_idx;\n  }\n\n  // The result is the same for every iteration, so we multiply by iters.\n  return total_sum_per_iter * static_cast<uint64_t>(iters);\n}",
