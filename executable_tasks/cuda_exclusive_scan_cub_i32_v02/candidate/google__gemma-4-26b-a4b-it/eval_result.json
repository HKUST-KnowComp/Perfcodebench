  "model_output_solution_source": "#include \"interface.h\"\n#include <cuda_runtime.h>\n#include <cub/cub.hpp>\n\nvoid exclusive_scan_i32(const int* input, int* output, int n, int iters) {\n    if (n <= 0) return;\n\n    // Determine temporary device storage requirements\n    void* d_temp_storage = nullptr;\n    size_t temp_storage_bytes = 0;\n\n    // First call to determine the amount of temporary storage needed\n    cub::DeviceExclusiveScan(input, output, n, d_temp_storage, temp_storage_bytes);\n\n    // Allocate temporary storage\n    cudaMalloc(&d_temp_storage, temp_storage_bytes);\n\n    for (int iter = 0; iter < iters; ++iter) {\n        // Perform the actual scan\n        cub::DeviceExclusiveScan(input, output, n, d_temp_storage);\n    }\n\n    // Clean up\n    cudaFree(d_temp_storage);\n}",
