  "model_output_solution_source": "#include \"interface.h\"\n\n#include <cstdint>\n#include <vector>\n\nuint64_t dictionary_distinct(\n    const std::vector<std::string>& dictionary,\n    const std::vector<uint16_t>& codes,\n    int iters) {\n  (void)dictionary;\n  \n  // Generation-tracked seen array avoids memset/clear overhead per iteration.\n  // uint16_t codes range from 0 to 65535, so size 65536 covers all possibilities.\n  std::vector<uint32_t> seen(65536, 0);\n  uint32_t gen = 0;\n  uint64_t count = 0;\n  \n  for (int iter = 0; iter < iters; ++iter) {\n    ++gen;\n    count = 0;\n    for (uint16_t code : codes) {\n      if (seen[code] != gen) {\n        seen[code] = gen;\n        ++count;\n      }\n    }\n  }\n  return count;\n}\n",
