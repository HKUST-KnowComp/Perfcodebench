  "model_output_solution_source": "#include \"interface.h\"\n#include <cstdint>\n#include <vector>\n\nuint64_t varint_sum(const std::vector<uint8_t>& encoded, int iters) {\n    const uint8_t* data = encoded.data();\n    const std::size_t len = encoded.size();\n    uint64_t total = 0;\n\n    for (int iter = 0; iter < iters; ++iter) {\n        uint64_t sum = 0;\n        std::size_t i = 0;\n        while (i < len) {\n            uint64_t value = 0;\n            uint32_t shift = 0;\n            uint8_t byte;\n            do {\n                byte = data[i++];\n                value |= uint64_t(byte & 0x7F) << shift;\n                shift += 7;\n            } while (byte & 0x80);\n            sum += value;\n        }\n        total = sum;\n    }\n    return total;\n}",
