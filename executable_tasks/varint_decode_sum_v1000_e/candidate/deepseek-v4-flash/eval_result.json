  "model_output_solution_source": "#include \"interface.h\"\n#include <cstdint>\n#include <vector>\n\nuint64_t varint_sum(const std::vector<uint8_t>& encoded, int iters) {\n    uint64_t sum = 0;\n    for (int iter = 0; iter < iters; ++iter) {\n        const uint8_t* ptr = encoded.data();\n        const uint8_t* end = ptr + encoded.size();\n        uint64_t iter_sum = 0;\n        while (ptr < end) {\n            uint64_t value = 0;\n            uint32_t shift = 0;\n            uint8_t byte;\n            do {\n                byte = *ptr++;\n                value |= (static_cast<uint64_t>(byte & 0x7F) << shift);\n                shift += 7;\n            } while (byte & 0x80);\n            iter_sum += value;\n        }\n        sum = iter_sum;\n    }\n    return sum;\n}\n",
