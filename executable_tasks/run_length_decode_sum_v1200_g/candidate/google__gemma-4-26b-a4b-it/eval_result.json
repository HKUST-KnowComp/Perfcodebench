  "model_output_solution_source": "#include \"interface.h\"\n\n#include <vector>\n\nuint64_t run_length_sum(\n    const std::vector<uint32_t>& values,\n    const std::vector<uint16_t>& lengths,\n    int iters) {\n  uint64_t total_sum = 0;\n  const std::size_t n = values.size();\n\n  for (int iter = 0; iter < iters; ++iter) {\n    uint64_t iter_sum = 0;\n    for (std::size_t i = 0; i < n; ++i) {\n      // Instead of expanding the RLE, we use the mathematical property:\n      // sum(value repeated L times) = value * L\n      iter_sum += static_cast<uint64_t>(values[i]) * lengths[i];\n    }\n    total_sum = iter_sum;\n  }\n\n  return total_sum;\n}",
