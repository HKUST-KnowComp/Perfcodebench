  "model_output_solution_source": "#include \"interface.h\"\n#include \"roaring.h\"\n\nuint64_t many_union_cardinality(\n    const std::vector<uint32_t>& offsets,\n    const std::vector<uint32_t>& values) {\n  if (offsets.size() < 2) return 0;\n\n  roaring_bitmap_t* r = roaring_bitmap_create();\n  if (!r) return 0;\n\n  for (size_t shard = 0; shard + 1 < offsets.size(); ++shard) {\n    const uint32_t begin = offsets[shard];\n    const uint32_t end   = offsets[shard + 1];\n    if (begin < end) {\n      roaring_bitmap_add_many(r, end - begin, values.data() + begin);\n    }\n  }\n\n  const uint64_t card = roaring_bitmap_get_cardinality(r);\n  roaring_bitmap_free(r);\n  return card;\n}",
