  "model_output_solution_source": "#include \"interface.h\"\n\n#include \"xxhash.h\"\n\n#include <cstddef>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1u << 10; // 1024 bytes\n}\n\nuint64_t chunked_hash(const std::string& input) {\n  const char* p = input.data();\n  std::size_t n = input.size();\n  uint64_t acc = 0;\n\n  // Process full 1KB chunks\n  while (n >= kChunkSize) {\n    acc ^= static_cast<uint64_t>(XXH32(p, kChunkSize, 0));\n    acc = (acc << 1) | (acc >> 63);\n    p += kChunkSize;\n    n -= kChunkSize;\n  }\n\n  // Process remaining tail (if any)\n  if (n != 0) {\n    acc ^= static_cast<uint64_t>(XXH32(p, n, 0));\n    acc = (acc << 1) | (acc >> 63);\n  }\n\n  return acc;\n}\n",
