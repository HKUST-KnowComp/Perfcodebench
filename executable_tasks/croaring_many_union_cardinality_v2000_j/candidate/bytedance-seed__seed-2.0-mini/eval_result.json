  "model_output_solution_source": "#include \"interface.h\"\n#include \"roaring.h\"\n\nuint64_t many_union_cardinality(\n    const std::vector<uint32_t>& offsets,\n    const std::vector<uint32_t>& values) {\n  roaring_bitmap_t* const bitmap = roaring_bitmap_create();\n  if (!bitmap) {\n    return 0;\n  }\n\n  for (std::size_t shard = 0; shard + 1 < offsets.size(); ++shard) {\n    const uint32_t begin = offsets[shard];\n    const uint32_t end = offsets[shard + 1];\n    const size_t count = end - begin;\n    if (count == 0) {\n      continue;\n    }\n    roaring_bitmap_add_many(bitmap, count, &values[begin]);\n  }\n\n  const uint64_t cardinality = roaring_bitmap_get_cardinality(bitmap);\n  roaring_bitmap_free(bitmap);\n  return cardinality;\n}",
