  "model_output_solution_source": "#include \"interface.h\"\n#include \"xxhash.h\"\n#include <algorithm>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1 << 10;\n}\n\nuint64_t chunked_hash(const std::string& input) {\n    const char* data = input.data();\n    const std::size_t size = input.size();\n    uint64_t acc = 0;\n    std::size_t offset = 0;\n\n    while (offset < size) {\n        std::size_t take = kChunkSize;\n        if (offset + take > size) {\n            take = size - offset;\n        }\n        \n        acc ^= static_cast<uint64_t>(XXH32(data + offset, take, 0));\n        acc = (acc << 1) | (acc >> 63);\n        offset += kChunkSize;\n    }\n    return acc;\n}",
