  "model_output_solution_source": "#include \"interface.h\"\n\n#include \"xxhash.h\"\n\n#include <algorithm>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1 << 10;\n}\n\nuint64_t chunked_hash(const std::string& input) {\n  uint64_t acc = 0;\n  XXH32_state_t* state = XXH32_createState();\n  \n  for (std::size_t offset = 0; offset < input.size(); offset += kChunkSize) {\n    const std::size_t take = std::min(kChunkSize, input.size() - offset);\n    XXH32_reset(state, 0);\n    XXH32_update(state, input.data() + offset, take);\n    acc ^= static_cast<uint64_t>(XXH32_digest(state));\n    acc = (acc << 1) | (acc >> 63);\n  }\n  \n  XXH32_freeState(state);\n  return acc;\n}",
