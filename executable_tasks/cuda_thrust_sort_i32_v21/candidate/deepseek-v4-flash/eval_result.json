  "model_output_solution_source": "#include \"interface.h\"\n#include <cuda_runtime.h>\n#include <thrust/sort.h>\n#include <thrust/device_ptr.h>\n#include <thrust/copy.h>\n\nvoid sort_vec_i32(const int* input, int* output, int n, int iters) {\n    thrust::device_ptr<const int> d_input(input);\n    thrust::device_ptr<int> d_output(output);\n\n    // Copy input to output once; Thrust::copy is synchronous\n    thrust::copy(d_input, d_input + n, d_output);\n\n    // Sort output repeatedly; Thrust uses radix sort for int32\n    for (int iter = 0; iter < iters; ++iter) {\n        thrust::sort(d_output, d_output + n);\n    }\n}\n",
