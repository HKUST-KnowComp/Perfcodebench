  "model_output_solution_source": "#include \"interface.h\"\n#include <stdint.h>\n#include <stddef.h>\n\nuint64_t run(const int32_t* deltas, size_t count, int iters) {\n  uint64_t total = 0;\n  if (count == 0) return 0;\n\n  for (int iter = 0; iter < iters; ++iter) {\n    uint64_t iter_total = 0;\n    int64_t current = 0;\n    \n    // Fused prefix sum and aggregation to avoid O(N) memory allocation and storage.\n    // This improves cache locality and allows for SIMD optimization.\n    for (size_t i = 0; i < count; ++i) {\n      current += (int64_t)deltas[i];\n      iter_total += (uint64_t)(current + 0x9E3779B1LL);\n    }\n    total = iter_total;\n  }\n  return total;\n}",
