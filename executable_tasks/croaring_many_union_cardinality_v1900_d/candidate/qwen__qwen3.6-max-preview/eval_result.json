  "model_output_solution_source": "#include \"interface.h\"\n#include <roaring.h>\n\nuint64_t many_union_cardinality(\n    const std::vector<uint32_t>& offsets,\n    const std::vector<uint32_t>& values) {\n    roaring_bitmap_t* bitmap = roaring_bitmap_create();\n    if (!bitmap) return 0;\n\n    for (std::size_t shard = 0; shard + 1 < offsets.size(); ++shard) {\n        uint32_t begin = offsets[shard];\n        uint32_t end = offsets[shard + 1];\n        if (end > begin) {\n            roaring_bitmap_add_many(bitmap, static_cast<size_t>(end - begin), &values[begin]);\n        }\n    }\n\n    uint64_t card = roaring_bitmap_get_cardinality(bitmap);\n    roaring_bitmap_free(bitmap);\n    return card;\n}",
