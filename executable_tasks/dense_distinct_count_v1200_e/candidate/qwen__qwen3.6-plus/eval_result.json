  "model_output_solution_source": "#include \"interface.h\"\n#include <vector>\n\nuint64_t distinct_count(const std::vector<uint32_t>& keys, uint32_t key_space, int iters) {\n    std::vector<uint32_t> seen(key_space, 0);\n    uint64_t count = 0;\n    for (int iter = 1; iter <= iters; ++iter) {\n        uint64_t cur = 0;\n        for (uint32_t k : keys) {\n            if (seen[k] != iter) {\n                seen[k] = iter;\n                ++cur;\n            }\n        }\n        count = cur;\n    }\n    return count;\n}",
