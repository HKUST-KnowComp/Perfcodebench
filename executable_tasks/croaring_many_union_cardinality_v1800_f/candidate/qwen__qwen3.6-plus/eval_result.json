  "model_output_solution_source": "#include \"interface.h\"\n#include \"roaring.h\"\n\nuint64_t many_union_cardinality(\n    const std::vector<uint32_t>& offsets,\n    const std::vector<uint32_t>& values) {\n    roaring_bitmap_t* r = roaring_bitmap_create();\n    for (std::size_t shard = 0; shard + 1 < offsets.size(); ++shard) {\n        uint32_t begin = offsets[shard];\n        uint32_t end = offsets[shard + 1];\n        if (begin < end) {\n            roaring_bitmap_add_many(r, end - begin, values.data() + begin);\n        }\n    }\n    uint64_t result = roaring_bitmap_get_cardinality(r);\n    roaring_bitmap_free(r);\n    return result;\n}",
