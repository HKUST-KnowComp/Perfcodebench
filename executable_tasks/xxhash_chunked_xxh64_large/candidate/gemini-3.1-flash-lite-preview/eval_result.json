  "model_output_solution_source": "#include \"interface.h\"\n#include \"xxhash.h\"\n#include <algorithm>\n#include <string>\n\nnamespace {\nconstexpr std::size_t kChunkSize = 1 << 10;\n}\n\nuint64_t chunked_hash(const std::string& input) {\n  uint64_t acc = 0;\n  const char* data = input.data();\n  const std::size_t size = input.size();\n  \n  for (std::size_t offset = 0; offset < size; offset += kChunkSize) {\n    const std::size_t take = std::min(kChunkSize, size - offset);\n    // Process chunk directly from the input buffer to avoid allocation\n    uint64_t chunk_hash = XXH64(data + offset, take, 0);\n    acc ^= chunk_hash;\n    // Rotate left by 1\n    acc = (acc << 1) | (acc >> 63);\n  }\n  return acc;\n}",
