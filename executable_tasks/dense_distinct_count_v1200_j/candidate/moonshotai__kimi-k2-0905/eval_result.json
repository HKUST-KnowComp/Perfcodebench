  "model_output_solution_source": "#include \"interface.h\"\n#include <vector>\n#include <cstdint>\n#include <bit>\n\nuint64_t distinct_count(const std::vector<uint32_t>& keys, uint32_t key_space, int iters) {\n    const uint32_t n_words = (key_space + 63) >> 6;\n    std::vector<uint64_t> bits(n_words, 0);\n    uint64_t count = 0;\n    for (int iter = 0; iter < iters; ++iter) {\n        std::fill(bits.begin(), bits.end(), 0);\n        for (uint32_t k : keys) {\n            const uint32_t idx = k >> 6;\n            const uint32_t bit = k & 63;\n            bits[idx] |= (1ULL << bit);\n        }\n        uint64_t pop = 0;\n        for (uint64_t w : bits) pop += std::popcount(w);\n        count = pop;\n    }\n    return count;\n}",
