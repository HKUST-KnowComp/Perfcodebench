  "model_output_solution_source": "def run(left: list[int], right: list[int], iters: int) -> int:\n    n = len(left)\n    if n == 0 or iters <= 0:\n        return 0\n\n    # Local bindings for faster access in tight loops.\n    l = left\n    r = right\n    total = 0\n\n    # Compute the exact AND-popcount each iteration.\n    # int.bit_count() is implemented in C and is much faster than\n    # materializing individual bits in Python.\n    for _ in range(iters):\n        s = 0\n        for i in range(n):\n            s += (l[i] & r[i]).bit_count()\n        total = s\n    return total\n",
