  "model_output_solution_source": "def run(left: list[int], right: list[int], iters: int) -> int:\n    # Compute the popcount of the bitwise AND across corresponding 64-bit words.\n    # Only the lower 64 bits are counted, matching the baseline behavior.\n    mask = (1 << 64) - 1\n    bc = int.bit_count\n\n    l = left\n    r = right\n    n = len(l)\n    m = len(r)\n    if m < n:\n        n = m\n\n    total = 0\n    i = 0\n    while i < n:\n        total += bc((l[i] & r[i]) & mask)\n        i += 1\n\n    return total\n",
